# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your Databricks workspace URL (required)
DATABRICKS_HOST=https://<your-workspace-url>.cloud.databricks.com

# MCP server app URL (get this after deploying mcp-server — see README Part 2)
MCP_SERVER_URL=https://<your-mcp-app-url>/mcp

# Lakebase instance name (must match what you created in the UI)
LAKEBASE_INSTANCE_NAME=agent-memory

# Embedding config (defaults work for most workspaces)
EMBEDDING_ENDPOINT=databricks-gte-large-en
EMBEDDING_DIMS=1024

# Deployed app URL (get this after deploying — see README Part 4)
# Used by test_agent.py; can also pass --app-url flag instead
APP_URL=https://<your-app-url>.databricksapps.com
