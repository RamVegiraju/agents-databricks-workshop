# Databricks workspace URL (e.g. https://adb-123456.7.azuredatabricks.net)
DATABRICKS_HOST=https://<your-workspace-url>.cloud.databricks.com

# MCP server URL — set after deploying (Part 2)
# Get it with: databricks apps get agent-mcp-server --output json | jq -r '.url'
# Then append /mcp
MCP_SERVER_URL=https://<your-mcp-app-url>/mcp
