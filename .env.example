# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your Databricks workspace URL (required)
DATABRICKS_HOST=https://<your-workspace-url>.cloud.databricks.com

# Lakebase instance name (must match what you created in the UI)
LAKEBASE_INSTANCE_NAME=agent-memory

# Embedding config (defaults work for most workspaces)
EMBEDDING_ENDPOINT=databricks-gte-large-en
EMBEDDING_DIMS=1024
